{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProxyPal",
  "version": "0.4.45",
  "identifier": "com.proxypal.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ProxyPal",
        "width": 800,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-src 'none'; form-action 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; media-src 'self' asset:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* http://localhost:1420 ws://localhost:1420;"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/cli-proxy-api"],
    "active": true,
    "targets": ["app", "dmg", "nsis", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Use your AI subscriptions everywhere",
    "longDescription": "ProxyPal lets you use your existing Claude, ChatGPT, Gemini, and Qwen subscriptions with any AI coding tool. No separate API keys needed.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["proxypal"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/heyhuynhgiabuu/proxypal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCODk2OEMwN0NDNjk0NTAKUldSUWxNWjh3R2lKSzZYSUdEWjVXKzAvTHVmd1FScDQrcHcrWVQxUEo0c2xYNkE0cFRmYmN1KzYK"
    }
  }
}
